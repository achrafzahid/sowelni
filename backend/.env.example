# Copy this to .env and fill in your values.
#   cp .env.example .env

# Required — get yours at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# Gemini model
GEMINI_MODEL=gemini-2.0-flash-lite

# ASR model — uses base model from HuggingFace for testing (~2 GB auto-download).
# After re-training, change to:  MODEL_DIR=./darija-asr-production
# MODEL_DIR=Qwen/Qwen3-ASR-0.6B
MODEL_DIR=../model

# Server
HOST=0.0.0.0
PORT=8000
